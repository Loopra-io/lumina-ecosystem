{
  "name": "@lumina/ui-primitives",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./components": {
      "import": "./dist/src/components/index.js",
      "types": "./dist/src/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/src/hooks/index.js",
      "types": "./dist/src/hooks/index.d.ts"
    },
    "./utils": {
      "import": "./dist/src/utils/index.js",
      "types": "./dist/src/utils/index.d.ts"
    },
    "./styles": "./dist/src/index.css"
  },
  "files": ["dist", "src"],
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "build": "tsc && cp src/index.css dist/index.css"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "framer-motion": "^12.38.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  }
}
