{
  "name": "@lumina/education-api",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./router": {
      "import": "./dist/router/index.js",
      "types": "./dist/router/index.d.ts"
    },
    "./procedures": {
      "import": "./dist/procedures/index.js",
      "types": "./dist/procedures/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "@trpc/server": "^11.0.0",
    "@lumina/core-types": "file:../core-types",
    "@lumina/data-access": "file:../data-access",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "ts-node": "^10.9.0"
  }
}
